generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  free
  pro
}

enum CheckinFrequency {
  weekly
  biweekly
  monthly
}

enum ExperienceSource {
  voice
  resume
  manual
}

enum VoiceSessionStatus {
  pending
  processed
}

enum ExperienceLevel {
  fresher
  experienced
}

model User {
  id                String          @id @default(cuid())
  whatsappId        String          @unique
  name              String?
  email             String?
  phone             String?
  location          String?
  linkedinUrl       String?
  jobTitle          String?
  company           String?
  interests         String?
  experienceLevel   ExperienceLevel @default(experienced)
  plan              Plan            @default(free)
  planExpiresAt     DateTime?
  checkinFrequency  CheckinFrequency @default(weekly)
  nextCheckinAt     DateTime?
  currentState      String?
  monthlyResumes    Int             @default(0)
  monthlyCheckins   Int             @default(0)
  createdAt         DateTime        @default(now())

  experiences    Experience[]
  educations     Education[]
  certifications Certification[]
  projects       Project[]
  skills         Skill[]
  languages      Language[]
  leaderships    Leadership[]
  voiceSessions  VoiceSession[]
  resumeExports  ResumeExport[]
}

model Experience {
  id          String           @id @default(cuid())
  userId      String
  title       String
  company     String?
  location    String?
  period      String?
  description String
  skills      String[]
  metrics     String[]
  source      ExperienceSource
  sessionId   String?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // company/period are null for voice-sourced entries, so Postgres treats those rows as
  // distinct (NULL never equals NULL in a unique index) — this only dedupes true PDF re-imports
  @@unique([userId, title, company, period])
}

model Education {
  id          String           @id @default(cuid())
  userId      String
  degree      String
  institution String?
  year        String?
  cgpa        String?
  source      ExperienceSource @default(resume)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, degree, institution])
}

model Leadership {
  id           String           @id @default(cuid())
  userId       String
  title        String
  organization String?
  period       String?
  location     String?
  bullets      String[]
  source       ExperienceSource @default(resume)
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title, organization])
}

model Certification {
  id            String           @id @default(cuid())
  userId        String
  name          String
  issuer        String?
  issuedYear    String?
  credentialUrl String?
  source        ExperienceSource @default(resume)
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Project {
  id          String           @id @default(cuid())
  userId      String
  title       String
  description String
  skills      String[]
  link        String?
  source      ExperienceSource @default(resume)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
}

model Skill {
  id        String           @id @default(cuid())
  userId    String
  name      String
  source    ExperienceSource @default(resume)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Language {
  id          String           @id @default(cuid())
  userId      String
  language    String
  proficiency String?
  source      ExperienceSource @default(resume)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, language])
}

model VoiceSession {
  id         String             @id @default(cuid())
  userId     String
  audioUrl   String
  transcript String?
  status     VoiceSessionStatus @default(pending)
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeExport {
  id             String    @id @default(cuid())
  userId         String
  jobDescription String
  resumeJson     String?
  templateName   String?
  fileUrl        String?
  linkToken      String    @unique
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
